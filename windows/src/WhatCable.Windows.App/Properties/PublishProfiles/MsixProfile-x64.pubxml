<?xml version="1.0" encoding="utf-8"?>
<!-- Publish profile for unpackaged MSIX (sideload) build. Run via VS Publish or:
	   dotnet publish src\WhatCable.Windows.App\WhatCable.Windows.App.csproj /p:PublishProfile=MsixProfile-x64
	 Output: bin\x64\Release\net8.0-windows10.0.19041.0\win-x64\AppPackages\ -->
<Project>
  <PropertyGroup>
	<Configuration>Release</Configuration>
	<Platform>x64</Platform>
	<RuntimeIdentifier>win-x64</RuntimeIdentifier>
	<PublishDir>bin\x64\Release\net8.0-windows10.0.19041.0\win-x64\msix\</PublishDir>
	<PublishProtocol>FileSystem</PublishProtocol>
	<_TargetId>Folder</_TargetId>
	<SelfContained>true</SelfContained>
	<PublishReadyToRun>false</PublishReadyToRun>
	<PublishSingleFile>false</PublishSingleFile>
	<WindowsPackageType>MSIX</WindowsPackageType>
	<WindowsAppSDKSelfContained>true</WindowsAppSDKSelfContained>
	<GenerateAppxPackageOnBuild>true</GenerateAppxPackageOnBuild>
	<AppxPackageSigningEnabled>true</AppxPackageSigningEnabled>
	<AppxBundle>Never</AppxBundle>
	<AppxBundlePlatforms>x64</AppxBundlePlatforms>
	<AppxPackageDir>..\..\installer\Output\AppPackages\</AppxPackageDir>
	<PackageCertificateKeyFile>Signing\WhatCable_TemporaryKey.pfx</PackageCertificateKeyFile>
	<!-- Skip Inno Setup for MSIX publishes. -->
	<RunInnoSetup>false</RunInnoSetup>
  </PropertyGroup>
</Project>
