<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="WhatCable.Windows.App.Views.TrayPopover"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border
        x:Name="Root"
        Padding="16"
        Background="Transparent">
        <Grid RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock
                Grid.Row="0"
                Text="WhatCable"
                Style="{ThemeResource SubtitleTextBlockStyle}" />

            <TextBlock
                Grid.Row="1"
                Text="{Binding StatusSummary}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Style="{ThemeResource CaptionTextBlockStyle}" />

            <!-- Liquid detection banner (Pro, UCSI 2.0) and upsell (non-Pro) -->
            <StackPanel Grid.Row="2" Spacing="4">
                <InfoBar
                    IsClosable="False"
                    IsOpen="{Binding IsLiquidDetected}"
                    Message="{Binding LiquidDetectionBanner}"
                    Severity="Error" />
                <InfoBar
                    x:Name="LiquidDetectionUpsell"
                    IsClosable="False"
                    IsOpen="{Binding ShowLiquidDetectionUpsell}"
                    Severity="Informational" />
            </StackPanel>

            <ListView
                Grid.Row="3"
                MaxHeight="320"
                IsItemClickEnabled="True"
                ItemClick="OnPortClicked"
                ItemsSource="{Binding Ports}"
                SelectionMode="None"
                Padding="0">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,2" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="6"
                            Padding="12,10">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    FontSize="20"
                                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                    Glyph="{Binding Glyph}" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                    <TextBlock
                                        Text="{Binding Headline}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Style="{ThemeResource CaptionTextBlockStyle}"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <FontIcon
                                    Grid.Column="2"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                    Glyph="&#xE76C;"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Power Monitor (Pro): system-wide watts -->
            <StackPanel Grid.Row="4" Spacing="2">
                <Grid Visibility="{Binding PowerMonitor.HasData, Converter={StaticResource BoolToVisibility}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        x:Name="PowerMonitorLabel"
                        Grid.Column="0"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{ThemeResource CaptionTextBlockStyle}" />
                    <TextBlock
                        Grid.Column="1"
                        Text="{Binding PowerMonitor.CurrentWattsText}"
                        Style="{ThemeResource BodyStrongTextBlockStyle}" />
                </Grid>
                <TextBlock
                    x:Name="PowerMonitorUpsell"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    TextWrapping="Wrap"
                    Visibility="{Binding PowerMonitor.ShowUpsell, Converter={StaticResource BoolToVisibility}}" />
            </StackPanel>

            <Grid Grid.Row="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <HyperlinkButton
                    x:Name="QuitButton"
                    Grid.Column="0"
                    Click="OnQuitClicked"
                    Content="Quit"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    FontSize="12"
                    Padding="4,2" />

                <Button
                    x:Name="SettingsButton"
                    Grid.Column="2"
                    Click="OnSettingsClicked"
                    Padding="8"
                    Background="Transparent"
                    BorderBrush="Transparent">
                    <FontIcon
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        Glyph="&#xE713;"
                        FontSize="16" />
                </Button>
            </Grid>
        </Grid>
    </Border>
</UserControl>
