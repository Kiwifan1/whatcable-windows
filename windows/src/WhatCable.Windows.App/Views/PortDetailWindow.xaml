<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="WhatCable.Windows.App.Views.PortDetailWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <Grid x:Name="Root" Padding="24" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <FontIcon
                    Grid.Column="0"
                    VerticalAlignment="Top"
                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                    FontSize="28"
                    Glyph="{Binding Glyph}" />
                <StackPanel Grid.Column="1" Spacing="2">
                    <TextBlock Text="{Binding Name}" Style="{ThemeResource TitleTextBlockStyle}" />
                    <TextBlock Text="{Binding Headline}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <TextBlock
                        Text="{Binding Subtitle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{ThemeResource BodyTextBlockStyle}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Grid>

            <!-- Unavailable -->
            <InfoBar
                x:Name="UnavailableBar"
                Grid.Row="1"
                IsClosable="False"
                IsOpen="{Binding IsUnavailable}"
                Severity="Informational" />

            <!-- Connected devices -->
            <StackPanel
                Grid.Row="2"
                Spacing="6"
                Visibility="{Binding HasDevices, Converter={StaticResource BoolToVisibility}}">
                <TextBlock x:Name="DevicesHeader" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <ListView ItemsSource="{Binding Devices}" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Padding="0,2">
                                <TextBlock Text="{Binding Name}" Style="{ThemeResource BodyTextBlockStyle}" />
                                <TextBlock
                                    Text="{Binding Speed}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{ThemeResource CaptionTextBlockStyle}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

            <!-- PD source -->
            <StackPanel
                Grid.Row="3"
                Spacing="6"
                Visibility="{Binding HasPowerProfiles, Converter={StaticResource BoolToVisibility}}">
                <TextBlock x:Name="PdHeader" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <ListView ItemsSource="{Binding PowerProfiles}" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnSpacing="8" Padding="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Name}" Style="{ThemeResource BodyTextBlockStyle}" />
                                <TextBlock Grid.Column="1" Text="{Binding MaxPowerW}" Style="{ThemeResource BodyTextBlockStyle}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

            <!-- Cable trust signals -->
            <StackPanel
                Grid.Row="4"
                Spacing="6"
                Visibility="{Binding HasTrustSignals, Converter={StaticResource BoolToVisibility}}">
                <TextBlock x:Name="TrustHeader" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <ListView ItemsSource="{Binding TrustSignals}" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Padding="0,2">
                                <TextBlock Text="{Binding Title}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <TextBlock
                                    Text="{Binding Detail}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{ThemeResource CaptionTextBlockStyle}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

            <!-- Cable summary -->
            <StackPanel
                Grid.Row="5"
                Spacing="4"
                Visibility="{Binding HasCable, Converter={StaticResource BoolToVisibility}}">
                <TextBlock x:Name="CableHeader" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <TextBlock
                    Text="{Binding Cable.VendorName}"
                    Style="{ThemeResource BodyTextBlockStyle}" />
                <TextBlock
                    Text="{Binding Cable.Speed}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{ThemeResource CaptionTextBlockStyle}" />
            </StackPanel>

            <!-- Pin diagram (Pro, UCSI) -->
            <StackPanel Grid.Row="6" Spacing="6">
                <TextBlock
                    x:Name="PinDiagramHeader"
                    Style="{ThemeResource BodyStrongTextBlockStyle}"
                    Visibility="{Binding SupportsPinDiagram, Converter={StaticResource BoolToVisibility}}" />
                <Image
                    x:Name="PinDiagramImage"
                    MaxWidth="320"
                    HorizontalAlignment="Left"
                    Stretch="Uniform"
                    Visibility="{Binding ShowPinDiagram, Converter={StaticResource BoolToVisibility}}" />
                <TextBlock
                    Text="{Binding PinDiagram.SignalSummary}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    TextWrapping="Wrap"
                    Visibility="{Binding ShowPinDiagram, Converter={StaticResource BoolToVisibility}}" />
                <InfoBar
                    x:Name="PinDiagramUpsellBar"
                    IsClosable="False"
                    IsOpen="{Binding ShowPinDiagramUpsell}"
                    Severity="Informational" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>
